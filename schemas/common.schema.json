{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./common.schema.json",
  "title": "Common schema definitions",
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+[a-z0-9._-]*$"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "isoDate": {
      "type": "string",
      "format": "date"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "hallmarkRef": {
      "$ref": "#/$defs/identifier"
    },
    "trackRef": {
      "$ref": "#/$defs/identifier"
    },
    "sourceRef": {
      "$ref": "#/$defs/identifier"
    },
    "sourceSnapshotRef": {
      "$ref": "#/$defs/identifier"
    },
    "studyRef": {
      "$ref": "#/$defs/identifier"
    },
    "findingRef": {
      "$ref": "#/$defs/identifier"
    },
    "outcomeRef": {
      "$ref": "#/$defs/identifier"
    },
    "resultRef": {
      "$ref": "#/$defs/identifier"
    },
    "synthesisGroupRef": {
      "$ref": "#/$defs/identifier"
    },
    "candidateChangeRef": {
      "$ref": "#/$defs/identifier"
    },
    "evidenceReviewRef": {
      "$ref": "#/$defs/identifier"
    },
    "agentRunRef": {
      "$ref": "#/$defs/identifier"
    },
    "sourceRightsRef": {
      "$ref": "#/$defs/identifier"
    },
    "textSnapshotRef": {
      "$ref": "#/$defs/identifier"
    },
    "sourceType": {
      "enum": [
        "journal_article",
        "review",
        "systematic_review",
        "meta_analysis",
        "preprint",
        "trial_registry",
        "regulatory_document",
        "database",
        "conference_abstract",
        "agent_curated_primary_source",
        "other"
      ]
    },
    "studyType": {
      "enum": [
        "randomized_trial",
        "nonrandomized_trial",
        "observational",
        "animal",
        "mechanistic",
        "in_vitro",
        "review",
        "systematic_review",
        "meta_analysis",
        "trial_registry",
        "other"
      ]
    },
    "studyStatus": {
      "enum": [
        "planned",
        "recruiting",
        "active",
        "completed",
        "terminated",
        "withdrawn",
        "unknown",
        "not_applicable"
      ]
    },
    "phase": {
      "enum": [
        "phase_1",
        "phase_1_2",
        "phase_2",
        "phase_2_3",
        "phase_3",
        "phase_4",
        "early_phase_1",
        "not_applicable",
        "unknown"
      ]
    },
    "endpointCategory": {
      "enum": [
        "mechanistic",
        "biomarker",
        "functional",
        "clinical",
        "healthspan",
        "lifespan",
        "safety",
        "registry_status",
        "other"
      ]
    },
    "evidenceDirection": {
      "enum": [
        "positive",
        "negative",
        "mixed",
        "null",
        "inconclusive",
        "not_applicable"
      ]
    },
    "evidenceTier": {
      "enum": [
        "mechanistic",
        "animal",
        "human_biomarker",
        "human_functional",
        "clinical_or_mortality",
        "review",
        "registry",
        "other"
      ]
    },
    "confidence": {
      "enum": [
        "low",
        "moderate",
        "high"
      ]
    },
    "maturityStatus": {
      "enum": [
        "metadata_imported",
        "screened",
        "triage_summary",
        "abstract_extracted",
        "registry_extracted",
        "full_text_extracted",
        "agent_reviewed",
        "supervisor_agent_reviewed",
        "accepted"
      ]
    },
    "accessTier": {
      "enum": [
        "open_reusable",
        "public_registry",
        "author_manuscript_or_preprint_repository",
        "metadata_only",
        "read_only_access",
        "blocked",
        "unknown"
      ]
    },
    "artifactClass": {
      "enum": [
        "raw_payload",
        "normalized_markdown",
        "section_index",
        "metadata_summary",
        "content_hash",
        "provenance_locator",
        "structured_extraction"
      ]
    },
    "sourceAccessPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "access_tier",
        "artifact_policy",
        "safe_artifact_classes",
        "basis",
        "checked_at"
      ],
      "properties": {
        "access_tier": {
          "$ref": "#/$defs/accessTier"
        },
        "artifact_policy": {
          "enum": [
            "retain_raw_and_markdown",
            "retain_raw_only",
            "retain_markdown_only",
            "retain_metadata_hashes_and_locators",
            "no_retention"
          ]
        },
        "safe_artifact_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactClass"
          },
          "uniqueItems": true
        },
        "basis": {
          "type": "string"
        },
        "license_or_terms": {
          "type": "string"
        },
        "checked_at": {
          "$ref": "#/$defs/dateTime"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "provenanceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "locator_type",
        "locator",
        "status"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/sourceRef"
        },
        "source_snapshot_id": {
          "$ref": "#/$defs/sourceSnapshotRef"
        },
        "text_snapshot_id": {
          "$ref": "#/$defs/textSnapshotRef"
        },
        "locator_type": {
          "enum": [
            "pubmed_metadata",
            "clinicaltrials_module",
            "abstract",
            "full_text_section",
            "table",
            "figure",
            "supplement",
            "registry_record",
            "derived_record",
            "agent_note",
            "other"
          ]
        },
        "locator": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/maturityStatus"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "provenanceLocators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provenanceLocator"
      },
      "uniqueItems": true
    },
    "coverageCategory": {
      "enum": [
        "human_interventional",
        "human_observational_or_natural_experiment",
        "animal_lifespan_or_healthspan",
        "mechanistic",
        "null_negative_or_limiting",
        "safety_durability",
        "active_trials_registries",
        "recent_reviews_meta_analyses",
        "seminal_anchors",
        "taxonomy_boundary"
      ]
    },
    "coverageLevel": {
      "enum": [
        "not_checked",
        "thin",
        "adequate",
        "strong",
        "not_applicable"
      ]
    },
    "coverageVerdict": {
      "enum": [
        "thin",
        "adequate",
        "strong"
      ]
    },
    "researchMode": {
      "enum": [
        "bootstrap",
        "surveillance",
        "coverage_repair",
        "extraction_refresh",
        "synthesis_refresh",
        "agent_directed"
      ]
    }
  }
}
