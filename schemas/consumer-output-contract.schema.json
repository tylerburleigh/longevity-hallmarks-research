{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./consumer-output-contract.schema.json",
  "title": "Consumer output contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "contract_version",
    "generated_at",
    "canonical_source_of_truth",
    "generated_export_root",
    "stability_model",
    "artifacts",
    "maturity_states",
    "release_boundaries",
    "required_consumer_checks",
    "non_authoritative_artifacts",
    "current_limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "consumer_output_contract"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "canonical_source_of_truth": {
      "type": "string"
    },
    "generated_export_root": {
      "type": "string"
    },
    "stability_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable",
        "experimental",
        "operational"
      ],
      "properties": {
        "stable": {
          "type": "string"
        },
        "experimental": {
          "type": "string"
        },
        "operational": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "format",
          "stability",
          "authority",
          "description",
          "record_types",
          "required_fields",
          "intended_uses",
          "prohibited_uses",
          "traceability_fields"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "format": {
            "enum": [
              "json",
              "jsonl",
              "sqlite"
            ]
          },
          "stability": {
            "enum": [
              "stable",
              "experimental",
              "operational"
            ]
          },
          "authority": {
            "enum": [
              "canonical_projection",
              "generated_index",
              "release_boundary",
              "control_plane",
              "manifest"
            ]
          },
          "description": {
            "type": "string"
          },
          "record_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "required_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "maturity_scope": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/maturityStatus"
            },
            "uniqueItems": true
          },
          "intended_uses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prohibited_uses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "traceability_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "maturity_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "state",
          "consumer_level",
          "meaning",
          "allowed_uses",
          "not_allowed_uses"
        ],
        "properties": {
          "state": {
            "$ref": "./common.schema.json#/$defs/maturityStatus"
          },
          "consumer_level": {
            "enum": [
              "triage",
              "extraction_grade",
              "reviewed",
              "accepted"
            ]
          },
          "meaning": {
            "type": "string"
          },
          "allowed_uses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "not_allowed_uses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "release_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary",
          "source",
          "meaning",
          "consumer_rule"
        ],
        "properties": {
          "boundary": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "meaning": {
            "type": "string"
          },
          "consumer_rule": {
            "type": "string"
          }
        }
      }
    },
    "required_consumer_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "description",
          "required_artifacts"
        ],
        "properties": {
          "check_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "description": {
            "type": "string"
          },
          "required_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "non_authoritative_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
