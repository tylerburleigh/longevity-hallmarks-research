{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./reconciliation-decision.schema.json",
  "title": "Reconciliation decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "created_at",
    "reconciled_by_agent",
    "reconciliation_report_id",
    "issue_ids",
    "issue_categories",
    "candidate_change_ids",
    "resolution_status",
    "resolution_summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "reconciliation_decision"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "reconciled_by_agent": {
      "type": "string"
    },
    "reconciliation_report_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "issue_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./common.schema.json#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "issue_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./parallel-reconciliation.schema.json#/$defs/findingCategory"
      },
      "uniqueItems": true
    },
    "candidate_change_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./common.schema.json#/$defs/candidateChangeRef"
      },
      "uniqueItems": true
    },
    "superseded_candidate_change_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/candidateChangeRef"
      },
      "uniqueItems": true
    },
    "compatible_candidate_change_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/candidateChangeRef"
      },
      "uniqueItems": true
    },
    "resolution_status": {
      "enum": [
        "resolved",
        "blocked",
        "superseded"
      ]
    },
    "resolution_summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "summary"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  }
}
