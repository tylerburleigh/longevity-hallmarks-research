{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./release-manifest.schema.json",
  "title": "Release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "generated_at",
    "export_version",
    "export_scope",
    "files",
    "record_counts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "release_manifest"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "generated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "export_version": {
      "type": "string"
    },
    "export_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "maturity_filters": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/maturityStatus"
          },
          "uniqueItems": true
        },
        "included_record_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "format",
          "description",
          "record_count",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "format": {
            "enum": [
              "json",
              "jsonl"
            ]
          },
          "description": {
            "type": "string"
          },
          "record_count": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "record_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
