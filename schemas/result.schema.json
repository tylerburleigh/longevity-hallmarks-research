{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./result.schema.json",
  "title": "Result record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "source_id",
    "study_id",
    "outcome_id",
    "result_type",
    "direction",
    "evidence_tier",
    "confidence",
    "statement"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "result"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/resultRef"
    },
    "name": {
      "type": "string"
    },
    "source_id": {
      "$ref": "./common.schema.json#/$defs/sourceRef"
    },
    "study_id": {
      "$ref": "./common.schema.json#/$defs/studyRef"
    },
    "outcome_id": {
      "$ref": "./common.schema.json#/$defs/outcomeRef"
    },
    "finding_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/findingRef"
      },
      "uniqueItems": true
    },
    "intervention_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "comparator": {
      "type": "string"
    },
    "arm_details": {
      "type": "string"
    },
    "sample_size": {
      "type": "integer",
      "minimum": 0
    },
    "group_values": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "group_id",
          "group_label",
          "value"
        ],
        "properties": {
          "group_id": {
            "type": "string"
          },
          "group_label": {
            "type": "string"
          },
          "sample_size": {
            "type": "integer",
            "minimum": 0
          },
          "statistic": {
            "enum": [
              "mean",
              "median",
              "count",
              "percent",
              "other"
            ]
          },
          "value": {
            "type": "number"
          },
          "lower_limit": {
            "type": "number"
          },
          "upper_limit": {
            "type": "number"
          },
          "dispersion": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          }
        }
      }
    },
    "result_type": {
      "enum": [
        "quantitative_effect",
        "descriptive",
        "posted_no_result",
        "no_posted_result",
        "safety_event",
        "registry_status",
        "other"
      ]
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "measure"
      ],
      "properties": {
        "measure": {
          "enum": [
            "mean_difference",
            "standardized_mean_difference",
            "risk_ratio",
            "odds_ratio",
            "hazard_ratio",
            "correlation",
            "percent_change",
            "p_value_only",
            "descriptive",
            "not_reported",
            "other"
          ]
        },
        "value": {
          "type": "number"
        },
        "ci_lower": {
          "type": "number"
        },
        "ci_upper": {
          "type": "number"
        },
        "standard_error": {
          "type": "number",
          "minimum": 0
        },
        "variance": {
          "type": "number",
          "minimum": 0
        },
        "p_value": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "raw_text": {
          "type": "string"
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comparison": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "p_value": {
          "type": "string"
        },
        "effect_note": {
          "type": "string"
        }
      }
    },
    "adverse_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferred_term",
        "term_source",
        "event_specific_counts",
        "zero_handling"
      ],
      "properties": {
        "preferred_term": {
          "type": "string"
        },
        "term_source": {
          "enum": [
            "publication_table",
            "trial_registry",
            "meddra",
            "source_text",
            "agent_normalized",
            "other"
          ]
        },
        "seriousness": {
          "enum": [
            "serious",
            "non_serious",
            "mixed",
            "not_reported"
          ]
        },
        "severity": {
          "enum": [
            "mild",
            "moderate",
            "severe",
            "mixed",
            "not_reported"
          ]
        },
        "relatedness": {
          "enum": [
            "related",
            "not_related",
            "mixed",
            "not_reported"
          ]
        },
        "event_specific_counts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/adverseEventArmCount"
          },
          "minItems": 1
        },
        "zero_handling": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "control_zero_status",
            "supports_comparative_effect"
          ],
          "properties": {
            "control_zero_status": {
              "enum": [
                "explicit_zero",
                "not_reported",
                "not_reported_or_below_threshold",
                "not_applicable",
                "unknown"
              ]
            },
            "supports_comparative_effect": {
              "type": "boolean"
            },
            "rationale": {
              "type": "string"
            }
          }
        }
      }
    },
    "direction": {
      "$ref": "./common.schema.json#/$defs/evidenceDirection"
    },
    "evidence_tier": {
      "$ref": "./common.schema.json#/$defs/evidenceTier"
    },
    "confidence": {
      "$ref": "./common.schema.json#/$defs/confidence"
    },
    "maturity_status": {
      "$ref": "./common.schema.json#/$defs/maturityStatus"
    },
    "provenance": {
      "$ref": "./common.schema.json#/$defs/provenanceLocators"
    },
    "statement": {
      "type": "string"
    },
    "time_horizon": {
      "type": "string"
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "adverseEventArmCount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arm_id",
        "arm_label",
        "sample_size",
        "count_status",
        "raw_value"
      ],
      "properties": {
        "arm_id": {
          "type": "string"
        },
        "arm_label": {
          "type": "string"
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        },
        "count_status": {
          "enum": [
            "reported_count",
            "explicit_zero",
            "not_reported",
            "not_reported_or_below_threshold",
            "not_applicable",
            "unknown"
          ]
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "percent": {
          "type": "number",
          "minimum": 0
        },
        "raw_value": {
          "type": "string"
        },
        "interpretation": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "count_status": {
                "enum": [
                  "reported_count",
                  "explicit_zero"
                ]
              }
            },
            "required": [
              "count_status"
            ]
          },
          "then": {
            "properties": {
              "event_count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "event_count"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "count_status": {
                "const": "explicit_zero"
              }
            },
            "required": [
              "count_status"
            ]
          },
          "then": {
            "properties": {
              "event_count": {
                "const": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "count_status": {
                "enum": [
                  "not_reported",
                  "not_reported_or_below_threshold",
                  "not_applicable",
                  "unknown"
                ]
              }
            },
            "required": [
              "count_status"
            ]
          },
          "then": {
            "not": {
              "properties": {
                "event_count": {}
              },
              "required": [
                "event_count"
              ]
            }
          }
        }
      ]
    }
  }
}
