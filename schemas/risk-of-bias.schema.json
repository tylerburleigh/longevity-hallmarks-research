{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./risk-of-bias.schema.json",
  "title": "Risk of bias record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "source_id",
    "study_id",
    "assessed_at",
    "tool",
    "overall_judgment",
    "domains"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "risk_of_bias"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "source_id": {
      "$ref": "./common.schema.json#/$defs/sourceRef"
    },
    "study_id": {
      "$ref": "./common.schema.json#/$defs/studyRef"
    },
    "assessed_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "reviewer_kind": {
      "enum": [
        "agent",
        "human"
      ]
    },
    "reviewer_id": {
      "type": "string"
    },
    "tool": {
      "enum": [
        "rob2",
        "robins_i",
        "syrcle",
        "grade",
        "custom_preclinical",
        "custom_registry",
        "custom_review",
        "other"
      ]
    },
    "overall_judgment": {
      "enum": [
        "low",
        "some_concerns",
        "high",
        "critical",
        "unclear",
        "not_applicable"
      ]
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "domain",
          "judgment",
          "rationale"
        ],
        "properties": {
          "domain": {
            "type": "string"
          },
          "judgment": {
            "enum": [
              "low",
              "some_concerns",
              "high",
              "critical",
              "unclear",
              "not_applicable"
            ]
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
