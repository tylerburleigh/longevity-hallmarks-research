{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./search-log.schema.json",
  "title": "Search log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "research_session_id",
    "searched_at",
    "agent_id",
    "scope",
    "queries",
    "coverage_effect",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "search_log"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "research_session_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "agent_run_id": {
      "$ref": "./common.schema.json#/$defs/agentRunRef"
    },
    "searched_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "agent_id": {
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/searchScope"
    },
    "search_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_names",
        "rationale"
      ],
      "properties": {
        "source_names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "rationale": {
          "type": "string"
        },
        "planned_queries": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query_id",
          "source_name",
          "query",
          "checked_at",
          "result_count",
          "retrieved_count"
        ],
        "properties": {
          "query_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "source_name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "checked_at": {
            "$ref": "./common.schema.json#/$defs/dateTime"
          },
          "url": {
            "$ref": "./common.schema.json#/$defs/url"
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "result_count": {
            "type": "integer",
            "minimum": 0
          },
          "retrieved_count": {
            "type": "integer",
            "minimum": 0
          },
          "no_op": {
            "type": "boolean"
          },
          "no_op_reason": {
            "type": "string"
          }
        }
      }
    },
    "hits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hit_id",
          "source_name",
          "title",
          "discovered_via_query_ids",
          "screening_status"
        ],
        "properties": {
          "hit_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "source_name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "$ref": "./common.schema.json#/$defs/url"
          },
          "external_ids": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "source_id": {
            "$ref": "./common.schema.json#/$defs/sourceRef"
          },
          "discovered_via_query_ids": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/identifier"
            },
            "uniqueItems": true
          },
          "screening_status": {
            "enum": [
              "unscreened",
              "included",
              "excluded",
              "duplicate",
              "wrong_scope",
              "awaiting_full_text",
              "context_only",
              "deferred"
            ]
          },
          "agent_note": {
            "type": "string"
          }
        }
      }
    },
    "canonical_source_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "coverage_effect": {
      "enum": [
        "new_candidates_found",
        "no_new_candidates",
        "query_exhausted",
        "blocked"
      ]
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "searchScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question"
      ],
      "properties": {
        "question": {
          "type": "string"
        },
        "hallmark_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/hallmarkRef"
          },
          "uniqueItems": true
        },
        "track_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/trackRef"
          },
          "uniqueItems": true
        },
        "intervention_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
