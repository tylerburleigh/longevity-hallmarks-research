{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./source-snapshot.schema.json",
  "title": "Source snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "source_id",
    "snapshot_type",
    "retrieved_at",
    "url",
    "content_type",
    "content_sha256",
    "payload_summary",
    "raw_storage"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "source_snapshot"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "source_id": {
      "$ref": "./common.schema.json#/$defs/sourceRef"
    },
    "snapshot_type": {
      "enum": [
        "pubmed_esummary",
        "pubmed_efetch",
        "clinicaltrials_v2_study",
        "agent_curated_primary_source",
        "other"
      ]
    },
    "retrieved_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "url": {
      "$ref": "./common.schema.json#/$defs/url"
    },
    "content_type": {
      "type": "string"
    },
    "content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "payload_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "access_policy": {
      "$ref": "./common.schema.json#/$defs/sourceAccessPolicy"
    },
    "raw_storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stored"
      ],
      "properties": {
        "stored": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "reason_not_stored": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "stored": {
                "const": true
              }
            },
            "required": [
              "stored"
            ]
          },
          "then": {
            "properties": {
              "path": {
                "type": "string"
              }
            },
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "stored": {
                "const": false
              }
            },
            "required": [
              "stored"
            ]
          },
          "then": {
            "properties": {
              "reason_not_stored": {
                "type": "string"
              }
            },
            "required": [
              "reason_not_stored"
            ]
          }
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
