        "summary"
      ]
    },
    {
      "id": "stale-parallel-reconciliation",
      "description": "Generated parallel reconciliation state must match canonical records and orchestration state.",
      "command": [
        "npm",
        "run",
        "audit:reconciliation"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "ops/reconciliation/parallel-reconciliation.v1.json",
          "pointer": "/summary/open_finding_count",
          "value": 999
        }
      ],
      "expected_failure_substrings": [
        "Parallel-reconciliation audit failed",
        "summary"
      ]
    },
    {
      "id": "promotion-blocked-by-unresolved-reconciliation",
      "description": "Promotion must fail when the candidate has unresolved reconciliation blockers.",
      "command": [
        "npm",
        "run",
        "promote:candidate",
        "--",
        "senolytics-bone-rct-extraction-refresh-2026-06-21",
        "--dry-run"
      ],
      "expected_failure_substrings": [
        "unresolved reconciliation finding",
        "overlapping_candidate_proposal"
      ]
    },
    {
      "id": "stale-reconciliation-decision",
      "description": "Reconciliation decisions must reference current report issues and matching categories.",
      "command": [
        "npm",
        "run",
        "audit:reconciliation"
      ],
      "operations": [
        {
          "type": "write_text",
          "path": "ops/reconciliation/decisions/bad-fixture-decision.json",
          "content": "{\n  \"schema_version\": \"1.0.0\",\n  \"record_type\": \"reconciliation_decision\",\n  \"id\": \"bad-fixture-decision\",\n  \"created_at\": \"2026-06-22T22:00:00Z\",\n  \"reconciled_by_agent\": \"fixture\",\n  \"reconciliation_report_id\": \"parallel-reconciliation-v1\",\n  \"issue_ids\": [\n    \"missing-current-issue\"\n  ],\n  \"issue_categories\": [\n    \"overlapping_candidate_proposal\"\n  ],\n  \"candidate_change_ids\": [\n    \"senolytics-bone-rct-extraction-refresh-2026-06-21\"\n  ],\n  \"resolution_status\": \"resolved\",\n  \"resolution_summary\": \"Fixture decision that must fail because the issue ID is not present in the current reconciliation report.\"\n}\n"
        },
        {
          "type": "set_json",
          "path": "ops/reconciliation/parallel-reconciliation.v1.json",
          "pointer": "/summary/reconciliation_decision_count",
          "value": 1
        }
      ],
      "expected_failure_substrings": [
        "unknown current reconciliation issue",
        "missing-current-issue"
      ]
    },
    {
      "id": "live-job-command-budget-too-low",
      "description": "Runnable live Codex jobs must use a command budget range that fits the job class.",
      "command": [
        "npm",
        "run",
        "audit:codex-jobs"
      ],
      "operations": [
        {
          "type": "write_text",
          "path": "ops/codex-jobs/live/fixture-low-command-budget.json",
          "content": "{\n  \"schema_version\": \"1.0.0\",\n  \"record_type\": \"codex_job\",\n  \"id\": \"fixture-low-command-budget\",\n  \"name\": \"Fixture low command budget\",\n  \"lifecycle_status\": \"ready\",\n  \"agent_role\": \"extraction_agent\",\n  \"mode\": \"extraction_refresh\",\n  \"prompt_file\": \"docs/prompts/codex-agents/extraction-refresh.md\",\n  \"output_path\": \"research/agent-runs/fixture-low-command-budget.json\",\n  \"jsonl_log_path\": \"research/agent-runs/logs/fixture-low-command-budget.jsonl\",\n  \"scope\": {\n    \"question\": \"Fixture extraction job with an intentionally undersized command-event cap.\"\n  },\n  \"execution\": {\n    \"isolation\": \"git_worktree\",\n    \"sandbox\": \"read-only\",\n    \"approval_policy\": \"never\",\n    \"output_schema_path\": \"schemas/agent-run.codex-output.schema.json\",\n    \"max_command_events\": 10\n  },\n  \"expected_outputs\": {\n    \"canonical_write_policy\": \"no_canonical_writes\"\n  },\n  \"orchestration\": {\n    \"read_sets\": [\n      \"source:fixture\"\n    ],\n    \"write_sets\": [],\n    \"conflict_keys\": [],\n    \"parallel_group\": \"extraction-refresh\",\n    \"reconciliation_required\": false,\n    \"expected_cost\": {\n      \"cost_class\": \"medium\",\n      \"expected_wall_time_ms\": 600000,\n      \"expected_token_budget\": 25000,\n      \"io_intensity\": \"medium\"\n    }\n  },\n  \"quality_gates\": []\n}\n"
        }
      ],
      "expected_failure_substrings": [
        "execution.max_command_events 10",
        "extraction command-budget profile range 60-140"
      ]
    },
    {
      "id": "archived-job-in-live-queue",
      "description": "Final job snapshots must not remain in the live runnable queue.",
      "command": [
        "npm",
        "run",
        "audit:codex-jobs"
      ],
      "operations": [
        {
          "type": "copy_file",
          "from": "ops/codex-jobs/archive/dq-bone-synthesis-groups-codex-worker-rerun-2026-06-21.json",
          "to": "ops/codex-jobs/live/dq-bone-synthesis-groups-codex-worker-rerun-2026-06-21.json"
        }
      ],
      "expected_failure_substrings": [
        "lifecycle_status \"succeeded\"",
        "must live under ops/codex-jobs/archive/"
      ]
    },
