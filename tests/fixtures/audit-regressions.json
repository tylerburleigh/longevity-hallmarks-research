    {
      "id": "unsafe-text-retention-export",
      "description": "Retained text snapshot exports must respect source-rights public export policy.",
      "command": [
        "npm",
        "run",
        "audit:exports"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "data/source-rights/source-rights-nct-04313634-2026-06-22.json",
