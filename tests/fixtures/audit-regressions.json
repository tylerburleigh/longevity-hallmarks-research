    {
      "id": "stale-batch-pending-reconciliation-after-import",
      "description": "Batch-run workers cannot remain pending reconciliation after their output exists in the coordinator checkout.",
      "command": [
        "npm",
        "run",
        "audit:parallel-batch-runs"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "ops/codex-batches/runs/parallel-synthetic-smoke-guard-level-2026-06-23.json",
          "pointer": "/status",
          "value": "partial"
        },
        {
          "type": "set_json",
          "path": "ops/codex-batches/runs/parallel-synthetic-smoke-guard-level-2026-06-23.json",
          "pointer": "/summary/succeeded_count",
          "value": 1
        },
        {
          "type": "set_json",
          "path": "ops/codex-batches/runs/parallel-synthetic-smoke-guard-level-2026-06-23.json",
          "pointer": "/summary/pending_reconciliation_count",
          "value": 1
        },
        {
          "type": "set_json",
          "path": "ops/codex-batches/runs/parallel-synthetic-smoke-guard-level-2026-06-23.json",
          "pointer": "/worker_states/0/status",
          "value": "succeeded_pending_reconciliation"
        },
        {
          "type": "set_json",
          "path": "ops/codex-batches/runs/parallel-synthetic-smoke-guard-level-2026-06-23.json",
          "pointer": "/worker_states/0/issues",
