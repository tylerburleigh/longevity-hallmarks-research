{
  "schema_version": "1.0.0",
  "description": "Negative audit regression fixtures. Each case mutates an isolated temp copy and expects the targeted audit to fail.",
  "cases": [
    {
      "id": "missing-extraction-grade-source-snapshot",
      "description": "Extraction-grade result provenance must retain source_snapshot_id.",
      "command": [
        "npm",
        "run",
        "audit:references"
      ],
      "operations": [
        {
          "type": "delete_json",
          "path": "data/results/dq-bone-ctx-20wk-null.json",
          "pointer": "/provenance/0/source_snapshot_id"
        }
      ],
      "expected_failure_substrings": [
        "extraction-grade provenance",
        "must include source_snapshot_id"
      ]
    },
    {
      "id": "unsupported-accepted-candidate",
      "description": "Candidates cannot be accepted without passing promotion gates.",
      "command": [
        "npm",
        "run",
        "audit:references"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "data/candidate-changes/senolytics-bone-rct-extraction-refresh-2026-06-21.json",
          "pointer": "/lifecycle_status",
          "value": "accepted"
        }
      ],
      "expected_failure_substrings": [
        "accepted/applied candidate must include promotion metadata",
        "non-accepting or blocking"
      ]
    },
    {
      "id": "duplicate-active-review-lane",
      "description": "A candidate may not link multiple active reviews for the same lane.",
      "command": [
        "npm",
        "run",
        "audit:references"
      ],
      "operations": [
        {
          "type": "copy_json",
          "from": "data/evidence-reviews/senolytics-dq-bone-endpoint-taxonomy-mapping-2026-06-21.json",
          "to": "data/evidence-reviews/senolytics-dq-bone-endpoint-taxonomy-mapping-duplicate-fixture.json",
          "mutations": [
            {
              "type": "set_json",
              "pointer": "/id",
              "value": "senolytics-dq-bone-endpoint-taxonomy-mapping-duplicate-fixture"
            }
          ]
        },
        {
          "type": "append_json_array",
          "path": "data/candidate-changes/senolytics-dq-bone-endpoint-synthesis-groups-2026-06-21.json",
          "pointer": "/evidence_review_ids",
          "value": "senolytics-dq-bone-endpoint-taxonomy-mapping-duplicate-fixture"
        }
      ],
      "expected_failure_substrings": [
        "multiple active reviews",
        "taxonomy_mapping"
      ]
    },
    {
      "id": "stale-export-content",
      "description": "Consumer exports must match current canonical records.",
      "command": [
        "npm",
        "run",
        "audit:exports"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "data/results/dq-bone-ctx-20wk-null.json",
          "pointer": "/statement",
          "value": "Regression fixture mutation that should make exports stale."
        }
      ],
      "expected_failure_substrings": [
        "contents do not match current canonical records",
        "run npm run export:latest"
      ]
    },
    {
      "id": "stale-triage-state",
      "description": "Generated triage state must match canonical records.",
      "command": [
        "npm",
        "run",
        "audit:triage-state"
      ],
      "operations": [
        {
          "type": "set_json",
          "path": "ops/triage-state.v1.json",
          "pointer": "/summary/recommended_job_count",
          "value": 999
        }
      ],
      "expected_failure_substrings": [
        "Triage-state audit failed",
        "summary"
      ]
    },
    {
      "id": "stale-release-readiness",
